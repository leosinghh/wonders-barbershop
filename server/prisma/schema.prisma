generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Service {
  id              Int       @id @default(autoincrement())
  name            String
  description     String
  durationMinutes Int
  price           Float
  bookings        Booking[]
}

model Booking {
  id         Int      @id @default(autoincrement())
  name       String
  email      String
  phone      String
  date       String
  time       String
  notes      String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  serviceId  Int
  service    Service  @relation(fields: [serviceId], references: [id])
}
